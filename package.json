{
  "name": "paywall",
  "version": "0.1.0",
  "private": true,
  "description": "Subscription billing backend service for SaaS applications.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.4",
    "pg": "^8.16.3",
    "redis": "^4.7.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babel/traverse": "^7.18.0",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.14.202",
    "@types/node": "^24.0.10",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.3",
    "semver": "^6.3.0",
    "supertest": "^7.1.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "word-wrap": "^1.2.3"
  }
}
